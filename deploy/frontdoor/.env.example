# AusMT public front door — VPS environment (C47 public bridge).
# Copy to deploy/frontdoor/.env on the VPS and fill in. NOTHING here is baked into git: these are the
# only place the public name and the box tailnet name live. `.env` is gitignored (see .gitignore).

# The public demo name served with an automatic Let's Encrypt certificate. This is the name whose
# DNS A/AAAA record you create at the registrar, pointing at the VPS public IP.
#   e.g. AUSMT_PUBLIC_NAME=ausmt.au
AUSMT_PUBLIC_NAME=

# The box reader upstream, reached over the tailnet by the box's MagicDNS name + the tailscale-serve
# reader port (the port you expose with `tailscale serve --tcp` on the box; the RUNBOOK uses 8445).
# http:// (not https://): the hop runs inside the WireGuard-encrypted tailnet; public TLS is this
# edge's job. Use the box's MagicDNS name, never a raw IP baked into config you might commit.
#   e.g. AUSMT_BOX_READER_UPSTREAM=http://ausmt-box:8445
AUSMT_BOX_READER_UPSTREAM=

# Contact email for the ACME (Let's Encrypt) account. Used only for expiry/issuance notices.
#   e.g. AUSMT_ACME_EMAIL=ops@example.org
AUSMT_ACME_EMAIL=
