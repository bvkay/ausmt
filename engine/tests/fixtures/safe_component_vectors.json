{
  "_comment": [
    "C38 item 4 (DATAID-lane, code-health review §6 M2 family): shared test vectors for the untrusted-",
    "id sanitiser. build_portal.safe_component turns an untrusted DATAID/slug into a path/URL/markup-safe",
    "token (keep [A-Za-z0-9._-], neutralise '..', strip leading dots/dashes, never empty). These vectors",
    "pin its exact behaviour on traversal, XSS, unicode and empty inputs.",
    "",
    "INTENDED to be consumed by TWO mirrors of the same contract:",
    "  1. engine/tests/test_safe_component_vectors.py -> build_portal.safe_component  (LANDED)",
    "  2. a jsdom assertion -> add-survey.html's safeEdiComponent  (NOT LANDED: add-survey.html has no",
    "     client-side sanitiser today — the portal parses/prints DATAID but the ausmt_id sanitisation is",
    "     server-side only. Adding a JS mirror is a new production function + a display-vs-server design",
    "     call for the owner; see the C38 report. When it lands, it consumes THIS SAME file so the two",
    "     copies cannot drift.)",
    "",
    "`fallback` is safe_component's default fallback ('x') used when the result would be empty."
  ],
  "fallback": "x",
  "vectors": [
    {"input": "S01", "expected": "S01", "kind": "plain"},
    {"input": "MBV20_LemiGraph", "expected": "MBV20_LemiGraph", "kind": "plain (underscore kept)"},
    {"input": "0000", "expected": "0000", "kind": "plain digits"},

    {"input": "../../etc/passwd", "expected": "etc-passwd", "kind": "traversal"},
    {"input": "site/../../x", "expected": "site-----x", "kind": "traversal (slashes + dotdot)"},
    {"input": "..", "expected": "x", "kind": "traversal (bare dotdot -> fallback)"},
    {"input": "....", "expected": "x", "kind": "traversal (all dots -> fallback)"},
    {"input": "a..b", "expected": "a-b", "kind": "traversal (embedded dotdot neutralised)"},

    {"input": "<img src=x onerror=alert(1)>", "expected": "img-src-x-onerror-alert-1--", "kind": "xss"},
    {"input": "quote\"mark", "expected": "quote-mark", "kind": "xss (quote stripped)"},
    {"input": "semi;colon", "expected": "semi-colon", "kind": "unsafe punctuation"},
    {"input": "back\\slash", "expected": "back-slash", "kind": "backslash"},
    {"input": "percent%20", "expected": "percent-20", "kind": "percent-encoding neutralised"},
    {"input": "a b c", "expected": "a-b-c", "kind": "spaces"},
    {"input": "TAB\tCHAR", "expected": "TAB-CHAR", "kind": "tab"},

    {"input": ".hidden", "expected": "hidden", "kind": "leading dot stripped"},
    {"input": "-leading-dash", "expected": "leading-dash", "kind": "leading dash stripped"},

    {"input": "café", "expected": "caf-", "kind": "unicode (accented -> replaced)"},
    {"input": "naïve-señor", "expected": "na-ve-se-or", "kind": "unicode (multiple accents)"},
    {"input": "日本語", "expected": "x", "kind": "unicode (CJK fully stripped -> fallback)"},

    {"input": "", "expected": "x", "kind": "empty -> fallback"},
    {"input": "   ", "expected": "x", "kind": "whitespace-only -> fallback"}
  ]
}
